-- Fruit-Lua | Professional Auto-Scanner & Server Hopper
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Player = game.Players.LocalPlayer

-- الرابط الخاص بسيرفرك على Railway
local API_URL = "https://blox-fruits-production.up.railway.app/report_fruit"

-- دالة القفز الذكي (فلترة السيرفرات)
local function hopToNextServer()
    print("جاري البحث عن سيرفر جديد...")
    local success, result = pcall(function()
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"
        local response = HttpService:JSONDecode(game:HttpGet(url))
        
        local validServers = {}
        for _, server in pairs(response.data) do
            -- فلترة: فقط السيرفرات غير الممتلئة (أقل من 20 لاعب)
            if server.playing < 20 and server.id ~= game.JobId then
                table.insert(validServers, server)
            end
        end
        
        if #validServers > 0 then
            local targetServer = validServers[math.random(1, #validServers)]
            print("الانتقال إلى السيرفر: " .. targetServer.id)
            TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, Player)
        end
    end)
    
    if not success then
        task.wait(10)
        hopToNextServer()
    end
end

-- دالة المسح
local function scanAndReport()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    local found = false
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        if fruit:GetAttribute("Rarity") == "Mythical" then
            found = true
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
            print("تم رصد فاكهة أسطورية في الموقع: " .. tostring(fruit.Position))
        end
    end
    return found
end

-- الحلقة الرئيسية (AFK Logic)
task.spawn(function()
    while true do
        if not scanAndReport() then
            print("لا توجد فواكه.. القفز لسيرفر آخر.")
            -- تأخير عشوائي لحماية الحساب من الكشف
            task.wait(math.random(30, 60)) 
            hopToNextServer()
        end
        task.wait(5)
    end
end)
