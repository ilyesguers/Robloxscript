local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- [1] الدومين الخاص بك على Railway (تمت إضافته)
local API_URL = "https://blox-fruits-production.up.railway.app/report_fruit"

-- دالة لإرسال إشعارات داخل اللعبة (Console)
local function logMessage(msg)
    print("[Fruit-Radar] " .. msg)
end

-- [2] نظام القفز المضاد للخطأ 773 (Anti-Cache)
local function Hop()
    logMessage("جاري البحث عن سيرفر جديد وآمن...")
    local PlaceID = game.PlaceId
    local AllIDs = {}
    local foundServer = false

    local success, err = pcall(function()
        -- استخدام دالة request الخاصة بالمشغل لتجنب الذاكرة المؤقتة (Cache)
        local req = (request or http_request or (syn and syn.request))
        if req then
            -- إضافة math.random في الرابط تخدع السيرفر ليعطيك بيانات جديدة كلياً
            local url = "https://games.roblox.com/v1/games/" .. tostring(PlaceID) .. "/servers/Public?sortOrder=Desc&excludeFullGames=true&limit=100&nocache=" .. tostring(math.random(1, 999999))
            local response = req({Url = url, Method = "GET"})
            local Data = HttpService:JSONDecode(response.Body)
            
            if Data and Data.data then
                for _, v in pairs(Data.data) do
                    -- فلترة صارمة: نبحث عن سيرفر عدد لاعبيه بين 3 و 10 (لتجنب السيرفرات الممتلئة أو التي يتم إغلاقها)
                    if type(v) == "table" and v.playing and v.maxPlayers and v.id ~= game.JobId then
                        if v.playing > 2 and v.playing < (v.maxPlayers - 2) then
                            table.insert(AllIDs, v.id)
                        end
                    end
                end
            end
        else
            -- إذا لم يدعم المشغل request، نستخدم الطريقة العادية مع كاسر الذاكرة
            local url = "https://games.roblox.com/v1/games/" .. tostring(PlaceID) .. "/servers/Public?sortOrder=Desc&excludeFullGames=true&limit=100&_=" .. tostring(math.random(1, 999999))
            local Site = game:HttpGet(url)
            local Data = HttpService:JSONDecode(Site)
            if Data and Data.data then
                for _, v in pairs(Data.data) do
                    if v.playing and v.playing < (v.maxPlayers - 2) and v.id ~= game.JobId then
                        table.insert(AllIDs, v.id)
                    end
                end
            end
        end
    end)
    
    if success and #AllIDs > 0 then
        -- اختيار سيرفر عشوائي من القائمة النظيفة
        local randomID = AllIDs[math.random(1, #AllIDs)]
        logMessage("تم إيجاد سيرفر! جاري الانتقال الآمن...")
        TeleportService:TeleportToPlaceInstance(PlaceID, randomID, Player)
    else
        logMessage("لم يتم العثور على سيرفرات، جاري استخدام الانتقال العشوائي...")
        -- الخطة ب: إذا فشل جلب السيرفرات، نستخدم دالة الانتقال العشوائي لروبلوكس (لا تسبب 773 غالباً)
        TeleportService:Teleport(PlaceID, Player)
    end
end

-- [3] دالة المسح والرادار
local function scanAndReport()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    local found = false
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        -- فحص إذا كانت الفاكهة أسطورية
        if fruit:GetAttribute("Rarity") == "Mythical" then
            found = true
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            
            -- إرسال البيانات فوراً إلى Railway
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
            logMessage("🎉 تم رصد فاكهة أسطورية: " .. fruit.Name)
        end
    end
    return found
end

-- [4] الحلقة الرئيسية (التشغيل التلقائي)
task.spawn(function()
    -- انتظار 8 ثواني بعد دخول السيرفر لضمان تحميل الخريطة بالكامل
    task.wait(8) 
    
    while true do
        if not scanAndReport() then
            logMessage("لا توجد فواكه.. جاري تجهيز القفز لسيرفر آخر.")
            task.wait(5) -- تأخير بسيط قبل القفز
            Hop()
            -- انتظار طويل بعد محاولة القفز لمنع الانهيار
            task.wait(40) 
        else
            logMessage("멈 السكربت توقف عن القفز. اذهب والتقط الفاكهة!")
            -- يتوقف السكربت عن العمل ليسمح لك باللعب
            break 
        end
    end
end)
