-- دالة القفز الاحترافية (تتجنب الحظر والخطأ 773)
local function SmartHop()
    if not _G.Running then return end
    print("[Fruit-Radar] جاري تحضير الانتقال الآمن...")
    
    local success, err = pcall(function()
        -- جلب خيارات الانتقال الرسمية من روبلوكس لضمان التوافق مع البحار (Seas)
        local teleportOptions = Instance.new("TeleportOptions")
        teleportOptions.ShouldReserveServer = false
        
        -- القفز باستخدام الدالة الحديثة الآمنة TeleportAsync
        TeleportService:TeleportAsync(game.PlaceId, {Player}, teleportOptions)
    end)
    
    if not success then
        print("[Fruit-Radar] فشل الانتقال، جاري المحاولة بالطريقة الاحتياطية...")
        task.wait(5)
        TeleportService:Teleport(game.PlaceId, Player)
    end
end

-- دالة فحص الفواكه
local function scan()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    local found = false
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        if fruit:GetAttribute("Rarity") == "Mythical" then
            found = true
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
        end
    end
    return found
end

-- التشغيل مع تأخير أمان لحماية الحساب من كشف الحماية
task.spawn(function()
    print("[Fruit-Radar] انتظار أمان لمنع الخطأ 773... يرجى الانتظار")
    task.wait(15) -- تأخير 15 ثانية كاملة لتهدئة نظام الحماية (Anti-Cheat)
    
    while true do
        if _G.Running then
            if not scan() then
                print("[Fruit-Radar] لم يتم العثور على فاكهة، جاري تغيير السيرفر...")
                task.wait(3)
                SmartHop()
                task.wait(30) -- انتظار طويل لضمان التنفيذ دون كراش
            else
                print("[Fruit-Radar] تم العثور على فاكهة! إيقاف السكربت لتلتقطها.")
                _G.Running = false
                ToggleButton.Text = "تم إيجاد فاكهة!"
                ToggleButton.BackgroundColor3 = Color3.fromRGB(241, 196, 15)
                break
            end
        end
        task.wait(2)
    end
end)
