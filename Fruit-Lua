-- Fruit-Lua | Ultimate Empty-Server Hopper & Scanner
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- الرابط الخاص بسيرفرك على Railway
local API_URL = "https://blox-fruits-production.up.railway.app/report_fruit"

-- دالة القفز إلى سيرفرات فارغة
local function hopToEmptyServer()
    print("جاري البحث عن سيرفر شبه فارغ...")
    local success, err = pcall(function()
        -- استخدام sortOrder=Asc يجلب السيرفرات الفارغة أو الأقل عدداً أولاً
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        local response = HttpService:JSONDecode(game:HttpGet(url))
        
        local emptyServers = {}
        if response and response.data then
            for _, server in pairs(response.data) do
                -- فلترة: نبحث عن سيرفرات بها أقل من 5 لاعبين لضمان الهدوء
                if type(server) == "table" and server.playing and server.maxPlayers then
                    if server.playing < 5 and server.id ~= game.JobId then
                        table.insert(emptyServers, server)
                    end
                end
            end
        end
        
        if #emptyServers > 0 then
            -- نختار سيرفر عشوائي من السيرفرات الفارغة لتجنب التكدس
            local targetServer = emptyServers[math.random(1, #emptyServers)]
            print("تم إيجاد سيرفر فارغ! عدد اللاعبين: " .. tostring(targetServer.playing) .. " - جاري الانتقال...")
            TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, Player)
        else
            print("لا توجد سيرفرات فارغة حالياً، سيتم المحاولة مرة أخرى...")
            task.wait(5)
            -- إذا لم يجد سيرفرات فارغة، يبحث بشكل عام مع التأكد من وجود مكان
            local backupUrl = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
            local backupResponse = HttpService:JSONDecode(game:HttpGet(backupUrl))
            if backupResponse and backupResponse.data then
                for _, s in pairs(backupResponse.data) do
                    if s.playing < s.maxPlayers - 2 and s.id ~= game.JobId then
                        print("الانتقال لسيرفر بديل...")
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, Player)
                        break
                    end
                end
            end
        end
    end)
    
    if not success then
        print("خطأ في الاتصال بالسيرفرات، جاري إعادة المحاولة...")
        task.wait(5)
        hopToEmptyServer()
    end
end

-- دالة مسح الفواكه
local function scanAndReport()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    local found = false
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        if fruit:GetAttribute("Rarity") == "Mythical" then
            found = true
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
            print("تم رصد فاكهة أسطورية في الموقع: " .. tostring(fruit.Position))
        end
    end
    return found
end

-- الحلقة الرئيسية
task.spawn(function()
    -- انتظار قصير عند بداية دخول السيرفر لضمان تحميل الخريطة
    task.wait(3) 
    
    while true do
        if not scanAndReport() then
            print("لا توجد فواكه.. جاري القفز لسيرفر فارغ آخر.")
            task.wait(math.random(10, 20)) -- تأخير ذكي لتجنب الحظر
            hopToEmptyServer()
        else
            -- إذا وجد فاكهة، يتوقف عن القفز وينتظرك
            print("تم العثور على فاكهة! السكربت في وضع الانتظار...")
            break 
        end
        task.wait(5)
    end
end)
