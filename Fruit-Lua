-- ==========================================
-- Fruit-Lua V7 | Auto-Pilot & Smart Hopper
-- ==========================================
getgenv().Team = "Marines"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")
local Player = Players.LocalPlayer

-- [1] تنبيهات على الشاشة (Notifications)
local function Notify(text)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Fruit-Radar",
        Text = text,
        Duration = 5
    })
end

-- [2] محرك الفحص الذكي (مع إشعار)
local function scanAndStore()
    local fruits = game.Workspace:FindFirstChild("Fruits")
    if not fruits then return false end
    for _, v in pairs(fruits:GetChildren()) do
        if v:GetAttribute("Rarity") == "Mythical" then
            Notify("🎉 وجدنا: " .. v.Name)
            Player.Character.HumanoidRootPart.CFrame = v.CFrame
            task.wait(1)
            ReplicatedStorage.Remotes.CommF_:InvokeServer("StoreFruit", string.gsub(v.Name, " Fruit", ""))
            return true
        end
    end
    return false
end

-- [3] محرك القفز الذكي (يتجاوز "السيرفر الفل")
local function SmartHop()
    Notify("جاري البحث عن سيرفر جديد...")
    -- بدلاً من الاعتماد على الأزرار (التي قد تكون فول)، نستخدم دالة القفز العشوائي
    -- نستخدم TeleportService للقفز الآمن
    TeleportService:Teleport(game.PlaceId, Player)
end

-- [4] حلقة الأوتوبيلوت (الروبوت)
task.spawn(function()
    Notify("الرادار يعمل الآن.. اترك الهاتف وأنا سأتولى الأمر!")
    while true do
        -- التأكد من اختيار الفريق
        pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("SetTeam", getgenv().Team) end)
        
        -- الفحص
        if scanAndStore() then
            task.wait(120) -- انتظر دقيقتين بعد إيجاد الفاكهة
        else
            -- محاولة تغيير السيرفر
            SmartHop()
            task.wait(45) -- وقت كافٍ للتحميل ولتجنب الحظر
        end
    end
end)
