local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local API_URL = "https://blox-fruits-production.up.railway.app/report_fruit"

-- دالة القفز الجديدة (لتفادي مشكلة التخزين المؤقت وخطأ 773)
local function Hop()
    local PlaceID = game.PlaceId
    local AllIDs = {}
    
    local success, err = pcall(function()
        -- جلب السيرفرات من الأقل للأكثر
        local Site = game:HttpGet("https://games.roblox.com/v1/games/" .. tostring(PlaceID) .. "/servers/Public?sortOrder=Asc&limit=100")
        local Data = HttpService:JSONDecode(Site)
        
        if Data and Data.data then
            for _, v in pairs(Data.data) do
                -- نتأكد أن السيرفر ليس سيرفرنا الحالي، وأن عدد اللاعبين أقل من 10 (لضمان وجود مكان حقيقي)
                if type(v) == "table" and v.playing ~= nil and v.id ~= game.JobId then
                    if v.playing < 10 then
                        table.insert(AllIDs, v.id)
                    end
                end
            end
        end
    end)
    
    if success and #AllIDs > 0 then
        -- اختيار سيرفر عشوائي من القائمة النظيفة
        local randomID = AllIDs[math.random(1, #AllIDs)]
        print("✅ تم إيجاد سيرفر مناسب! جاري الانتقال...")
        TeleportService:TeleportToPlaceInstance(PlaceID, randomID, Player)
    else
        print("⚠️ لم يتم العثور على سيرفرات مناسبة، سيتم إعادة المحاولة...")
        task.wait(10)
        Hop()
    end
end

-- دالة المسح والرادار
local function scanAndReport()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    local found = false
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        if fruit:GetAttribute("Rarity") == "Mythical" then
            found = true
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
            print("🎉 تم رصد فاكهة أسطورية!")
        end
    end
    return found
end

-- الحلقة الرئيسية
task.spawn(function()
    -- [مهم جداً] انتظار 6 ثواني بعد دخول اللعبة حتى يتصل مشغل Delta بخوادم روبلوكس بشكل سليم
    task.wait(6) 
    
    while true do
        if not scanAndReport() then
            print("🔄 لا توجد فواكه.. جاري تجهيز القفز.")
            task.wait(3) -- راحة قصيرة قبل القفز
            Hop()
            -- انتظار طويل جداً بعد القفز، فإذا فشل الانتقال لا يقوم بعمل Spam للسيرفرات
            task.wait(40) 
        else
            print("멈 السكربت توقف عن القفز. اذهب والتقط الفاكهة!")
            break 
        end
    end
end)
