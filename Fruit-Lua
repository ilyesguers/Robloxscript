-- ==========================================
-- Fruit-Lua V6 | Native Team Injection
-- ==========================================
-- هذا الجزء هو "السر" الذي يجعله يختار المارينز فوراً مثل السكربتات الاحترافية
getgenv().Team = "Marines" 

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = Players.LocalPlayer

-- [1] دالة اختيار الفريق الاحترافية (تستخدم نفس الطريقة الاحترافية)
local function ForceTeam()
    pcall(function()
        local args = { [1] = "SetTeam", [2] = getgenv().Team }
        ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
    end)
end

-- [2] محرك الفحص والتخزين (بدون انتظار القوائم)
local function scan()
    local fruits = game.Workspace:FindFirstChild("Fruits")
    if not fruits then return end
    for _, v in pairs(fruits:GetChildren()) do
        if v:GetAttribute("Rarity") == "Mythical" then
            warn("🎉 FOUND: " .. v.Name)
            -- الانتقال الفوري
            Player.Character.HumanoidRootPart.CFrame = v.CFrame
            task.wait(0.5)
            -- التخزين
            ReplicatedStorage.Remotes.CommF_:InvokeServer("StoreFruit", string.gsub(v.Name, " Fruit", ""))
            return true
        end
    end
    return false
end

-- [3] حلقة التشغيل المباشرة
task.spawn(function()
    -- المحاولة الأولى فوراً عند التشغيل
    ForceTeam() 
    
    while true do
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            if scan() then
                task.wait(60) -- إذا وجد فاكهة، انتظر دقيقة
            else
                -- القفز الآمن (الذي لا يسبب 773)
                game:GetService("TeleportService"):Teleport(game.PlaceId, Player)
            end
        else
            ForceTeam() -- حاول اختيار الفريق مرة أخرى إذا لم تدخل العالم
        end
        task.wait(20)
    end
end)
