-- ==========================================
-- Fruit-Lua | Flawless In-Game Server Hopper & Scanner
-- ==========================================
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local API_URL = "https://blox-fruits-production.up.railway.app/report_fruit"

-- متغيرات التحكم في السكربت
_G.ScriptEnabled = true

-- ==========================================
-- [1] إنشاء واجهة المستخدم (GUI) البسيطة
-- ==========================================
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local ToggleButton = Instance.new("TextButton")

ScreenGui.Parent = game:GetService("CoreGui") or Player:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

MainFrame.Name = "FruitRadarGui"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Position = UDim2.new(0.05, 0, 0.15, 0) -- يظهر في الجانب العلوي الأيسر لشاشة الهاتف
MainFrame.Size = UDim2.new(0, 160, 0, 50)
MainFrame.Active = true
MainFrame.Draggable = true -- يمكنك سحبه بإصبعك في أي مكان بالشاشة

ToggleButton.Name = "ToggleButton"
ToggleButton.Parent = MainFrame
ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113) -- لون أخضر عند التشغيل
ToggleButton.Size = UDim2.new(1, 0, 1, 0)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.Text = "الرادار: مشغل (ON)"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.TextSize = 16

-- وظيفة زر التشغيل والإيقاف
ToggleButton.MouseButton1Click:Connect(function()
    _G.ScriptEnabled = not _G.ScriptEnabled
    if _G.ScriptEnabled then
        ToggleButton.Text = "الرادار: مشغل (ON)"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        print("[Fruit-Radar] تم إعادة تشغيل السكربت تلقائياً.")
    else
        ToggleButton.Text = "الرادار: متوقف (OFF)"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60) -- لون أحمر عند الإيقاف
        print("[Fruit-Radar] تم إيقاف السكربت مؤقتاً.")
    end
end)

-- ==========================================
-- [2] نظام الانتقال والمسح (In-Game Matchmaking)
-- ==========================================

-- دالة القفز الآمن باستخدام نظام اللعبة الرسمي
local function safeInGameHop()
    if not _G.ScriptEnabled then return end
    print("[Fruit-Radar] جاري الانتقال الآمن عبر نظام روبلوكس الداخلي...")
    
    local success, err = pcall(function()
        -- هذه الدالة تبحث تلقائياً عن سيرفر عام عشوائي متاح ومحدث بدون كاش خارجي
        TeleportService:Teleport(game.PlaceId, Player)
    end)
    
    if not success then
        print("[Fruit-Radar] فشل الانتقال، إعادة المحاولة بعد 10 ثوانٍ...")
        task.wait(10)
        safeInGameHop()
    end
end

-- دالة مسح ورصد الفواكه
local function scanAndReport()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    local found = false
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        if fruit:GetAttribute("Rarity") == "Mythical" then
            found = true
            print("🎉 [تنبيه] تم العثور على فاكهة أسطورية: " .. fruit.Name)
            
            -- إرسال البيانات إلى Railway الخاص بك
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
        end
    end
    return found
end

-- ==========================================
-- [3] الحلقة الرئيسية للتشغيل
-- ==========================================
task.spawn(function()
    task.wait(7) -- انتظار تحميل خريطة اللعبة عند الدخول لمنع الكراش
    print("[Fruit-Radar] السكربت جاهز للعمل.")
    
    while true do
        if _G.ScriptEnabled then
            if not scanAndReport() then
                print("[Fruit-Radar] لا توجد فواكه ميثيك، الاستعداد للقفز...")
                task.wait(5) -- مهلة قصيرة لحماية الذاكرة
                safeInGameHop()
                task.wait(30) -- انتظار طويل لضمان انتهاء محاولة القفز
            else
                -- إذا وجد فاكهة، يقوم بإيقاف السكربت تلقائياً حتى لا يقفز ويترك الفاكهة
                _G.ScriptEnabled = false
                ToggleButton.Text = "تم إيجاد فاكهة! (OFF)"
                ToggleButton.BackgroundColor3 = Color3.fromRGB(241, 196, 15) -- لون أصفر للتنبيه
                break
            end
        end
        task.wait(2)
    end
end)
