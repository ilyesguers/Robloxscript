-- ==========================================
-- Fruit-Lua V10 | Physical UI Automation & Anti-773 Daemon
-- ==========================================
getgenv().Team = "Marines"

-- قائمة الفواكه المستهدفة
local TargetFruits = {
    "kitsune", "dragon", "leopard", "tiger", "gas", 
    "dough", "trex", "yeti", "mammoth", "control", 
    "venom", "shadow", "gravity"
}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")
local CoreGui = game:GetService("CoreGui")
local Player = Players.LocalPlayer

-- دالة محاكاة الضغط الآمن على الأزرار
local function safeClick(button)
    if not button then return end
    pcall(function()
        if firesignal then
            firesignal(button.MouseButton1Click)
            firesignal(button.Activated)
        else
            if button.MouseButton1Click then button.MouseButton1Click:Fire() end
            if button.Activated then button.Activated:Fire() end
        end
    end)
end

-- [1] تنبيهات الشاشة
local function Notify(text, duration)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Fruit-Radar V10",
            Text = text,
            Duration = duration or 4
        })
    end)
end

-- [2] قاهر الأخطاء تلقائياً (تخطي شاشة خطأ 773 / 772 المزعجة)
local function dismissErrorPopup()
    local robloxPrompt = CoreGui:FindFirstChild("RobloxPromptGui")
    if robloxPrompt then
        local okButton = robloxPrompt:FindFirstChild("OkButton", true)
        if okButton and okButton.Visible then
            Notify("💥 تم رصد عدونا اللدود (Error)! جاري إغلاقه تلقائياً...", 4)
            safeClick(okButton)
            task.wait(2)
            return true
        end
    end
    return false
end

-- [3] محرك الفحص والتخزين التلقائي للفواكه
local function scanAndStore()
    local fruits = game.Workspace:FindFirstChild("Fruits")
    if not fruits then return false end
    
    for _, v in pairs(fruits:GetChildren()) do
        local nameLower = string.lower(v.Name)
        local shouldCollect = false
        
        for _, filter in pairs(TargetFruits) do
            if string.find(nameLower, filter) then
                shouldCollect = true
                break
            end
        end
        
        if shouldCollect then
            Notify("🎉 رادار الفواكه وجد: " .. v.Name, 10)
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                Player.Character.HumanoidRootPart.CFrame = v.CFrame
                task.wait(1.5)
                local fruitNameForStore = string.gsub(v.Name, " Fruit", "")
                pcall(function()
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("StoreFruit", fruitNameForStore)
                end)
                return true
            end
        end
    end
    return false
end

-- [4] فتح القائمة واختيار سيرفر آمن لأسفل القائمة (UI Server Hopper)
local function OpenMenuAndHop()
    -- أولاً: التأكد من عدم وجود أي نافذة خطأ مغطية على الشاشة
    dismissErrorPopup()

    Notify("🤖 جاري فتح قائمة السيرفرات العلوية...", 3)
    
    -- البحث عن زر قائمة السيرفرات في أعلى يمين الشاشة وضغطه
    local serverMenuButton = nil
    for _, v in pairs(Player.PlayerGui:GetDescendants()) do
        if v:IsA("ImageButton") or v:IsA("TextButton") then
            if string.find(string.lower(v.Name), "server") or (v.AbsolutePosition.X > 600 and v.AbsolutePosition.Y < 120 and v.Visible) then
                serverMenuButton = v
                break
            end
        end
    end

    if serverMenuButton then
        safeClick(serverMenuButton)
        task.wait(3) -- وقت كافٍ لتظهر القائمة أمامك وتتحمل السيرفرات بالكامل
        
        -- تجميع كل أزرار الـ "Join" الموجودة داخل القائمة المفتوحة
        local joinButtons = {}
        for _, v in pairs(Player.PlayerGui:GetDescendants()) do
            if v:IsA("TextButton") and (v.Text == "Join" or string.find(v.Name, "Join")) and v.Visible then
                table.insert(joinButtons, v)
            end
        end
        
        if #joinButtons > 0 then
            -- تطبيق فكرتك: النزول لأسفل القائمة وتخطي أول 5 سيرفرات (لأنها دائماً ممتلئة وتسبب الخطأ)
            local startIndex = math.min(6, #joinButtons)
            local endIndex = math.min(18, #joinButtons)
            
            if startIndex <= endIndex then
                local targetBtn = joinButtons[math.random(startIndex, endIndex)]
                Notify("🚀 تم اختيار سيرفر غير ممتلئ بنجاح! جاري الدخول...", 4)
                safeClick(targetBtn)
            else
                -- إذا كانت القائمة قصيرة، يختار آخر سيرفر متاح لضمان البعد عن الازدحام
                safeClick(joinButtons[#joinButtons])
            end
        else
            Notify("⚠️ لم تظهر أزرار السيرفرات بعد، إعادة المحاولة...", 3)
        end
    else
        Notify("❌ تعذر العثور على زر القائمة العلوي، جاري النقل الاحتياطي...", 3)
        TeleportService:Teleport(game.PlaceId, Player)
    end
end

-- ربط فوري في حال فشل الانتقال أثناء النوم ليعيد تكرار المحاولة فوراً وبدون توقف
TeleportService.TeleportInitFailed:Connect(function()
    task.wait(1)
    dismissErrorPopup()
    OpenMenuAndHop()
end)

-- [5] الحلقة الأساسية (Main AFK Loop)
task.spawn(function()
    task.wait(5)
    Notify("⚙️ تم تشغيل الرادار بنظام محاكاة القائمة المفتوحة ومكافحة الأخطاء.", 8)
    
    while true do
        -- التحقق التلقائي من إغلاق النوافذ المزعجة
        dismissErrorPopup()
        
        -- اختيار فريق المارينز وتخطي القائمة الترحيبية
        pcall(function() 
            if Player.Team == nil or Player.Team.Name ~= getgenv().Team then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("SetTeam", getgenv().Team) 
            end
        end)
        
        task.wait(2)
        
        -- بدء الفحص
        if scanAndStore() then
            Notify("✅ تم تأمين الفاكهة في الحقيبة! جاري الانتقال لسيرفر آخر...", 4)
            task.wait(3)
            OpenMenuAndHop()
        else
            -- إذا لم يجد الفواكه المطلوبة، يفتح القائمة وينتقل فوراً
            OpenMenuAndHop()
        end
        
        task.wait(40) -- حماية تمنع تعليق اللعبة أثناء شاشات التحميل الممتدة
    end
end)
