-- ==========================================
-- Fruit-Lua | UI-Automated Hopper & Auto-Fly
-- ==========================================
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local Player = Players.LocalPlayer

local API_URL = "https://blox-fruits-production.up.railway.app/report_fruit"
_G.AutoHop = true

-- [1] دالة الطيران الآمن نحو الفاكهة (لتجنب الحظر)
local function FlyToFruit(targetCFrame)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local rootPart = character:WaitForChild("HumanoidRootPart")
    
    -- حساب المسافة لضبط سرعة الطيران (300 تعتبر سريعة وآمنة)
    local distance = (rootPart.Position - targetCFrame.Position).Magnitude
    local timeToFly = distance / 300 
    
    local tweenInfo = TweenInfo.new(timeToFly, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = targetCFrame})
    
    print("[Fruit-Radar] 🚀 جاري الطيران نحو الفاكهة الأسطورية!")
    tween:Play()
    tween.Completed:Wait()
    print("[Fruit-Radar] ✅ وصلنا للفاكهة! التقطها بسرعة.")
end

-- [2] دالة المسح وإرسال البيانات
local function scanAndCollect()
    local fruitsFolder = Workspace:FindFirstChild("Fruits")
    if not fruitsFolder then return false end
    
    for _, fruit in pairs(fruitsFolder:GetChildren()) do
        if fruit:GetAttribute("Rarity") == "Mythical" then
            print("🎉 [تنبيه] تم العثور على فاكهة ميثيك!")
            
            -- إرسال البيانات فوراً
            local data = {
                name = fruit.Name,
                position = {x = fruit.Position.X, y = fruit.Position.Y, z = fruit.Position.Z},
                server_id = game.JobId
            }
            pcall(function()
                HttpService:PostAsync(API_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
            end)
            
            -- الطيران للفاكهة
            FlyToFruit(fruit.CFrame)
            return true
        end
    end
    return false
end

-- [3] دالة ضغط أزرار القائمة (الخدعة العبقرية)
local function clickInGameServerJoin()
    local joinButtons = {}
    
    -- البحث في كل واجهات اللعبة عن أزرار الانضمام للسيرفرات
    for _, obj in pairs(Player.PlayerGui:GetDescendants()) do
        if obj:IsA("TextButton") and (obj.Text == "Join" or obj.Name == "JoinButton") then
            -- نأخذ الأزرار الظاهرة فقط
            if obj.Visible then
                table.insert(joinButtons, obj)
            end
        end
    end
    
    if #joinButtons > 0 then
        -- اختيار سيرفر من المنتصف أو النهاية (كما اقترحت)
        local startIndex = math.floor(#joinButtons / 2)
        if startIndex < 1 then startIndex = 1 end
        local randomBtn = joinButtons[math.random(startIndex, #joinButtons)]
        
        print("[Fruit-Radar] جاري محاكاة ضغطة زر 'Join' على سيرفر من القائمة...")
        
        -- إجبار اللعبة على تنفيذ أمر الزر (محاكاة الضغطة)
        if getconnections then
            for _, connection in pairs(getconnections(randomBtn.MouseButton1Click)) do
                connection:Fire()
            end
        elseif firesignal then
            firesignal(randomBtn.MouseButton1Click)
        else
            print("⚠️ مشغلك لا يدعم محاكاة النقرات، يرجى الضغط يدوياً.")
        end
    else
        print("[Fruit-Radar] ⚠️ لم أجد أزرار السيرفرات.")
        print("💡 تلميح: افتح قائمة السيرفرات يدوياً مرة واحدة ليتمكن السكربت من رؤية الأزرار.")
    end
end

-- [4] حلقة التشغيل الرئيسية
task.spawn(function()
    task.wait(8) -- انتظار تحميل الخريطة لمنع الكراش
    
    while _G.AutoHop do
        if scanAndCollect() then
            -- إذا وجد الفاكهة يوقف القفز فوراً
            _G.AutoHop = false
            print("멈 تم إيقاف القفز، الفاكهة أمامك!")
            break
        else
            print("[Fruit-Radar] لا يوجد شيء.. جاري الضغط على سيرفر آخر.")
            task.wait(2)
            clickInGameServerJoin()
            task.wait(25) -- انتظار طويل لكي يأخذ أمر النقل وقته دون كراش
        end
    end
end)
